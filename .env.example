# Cawnex Environment Variables
# Copy to .env and fill in your values

# Database Configuration
# PostgreSQL connection string for the main database
CAWNEX_DATABASE_URL=postgresql+asyncpg://cawnex:cawnex@localhost:5433/cawnex

# Redis Configuration
# Redis connection string for caching and background tasks
CAWNEX_REDIS_URL=redis://localhost:6380

# Encryption Configuration
# Fernet key for encrypting sensitive data like API keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CAWNEX_FERNET_KEY=

# GitHub Integration
# Personal Access Token with repo scope for creating PRs and reading issues
# Optional: Leave empty to disable GitHub integration
CAWNEX_GITHUB_TOKEN=

# Subscription Features
# Enable or disable subscription-based features (true/false)
CAWNEX_USE_SUBSCRIPTION=false

# Claude Command Override
# Custom command to use instead of default Claude behavior
# Optional: Leave empty to use default
CAWNEX_CLAUDE_CMD=

# Legacy Environment Variables (for backwards compatibility)
# These may be referenced by older parts of the codebase
DATABASE_URL=postgresql+asyncpg://cawnex:cawnex@localhost:5433/cawnex
REDIS_URL=redis://localhost:6380
ENCRYPTION_KEY=
GITHUB_TOKEN=

# GitHub webhook secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
GITHUB_WEBHOOK_SECRET=

# Anthropic API key (BYOL — added after The Egg is built)
# ANTHROPIC_API_KEY=