# Cawnex Environment Variables
# Copy to .env and fill in your values

# Database (Docker Compose default)
DATABASE_URL=postgresql+asyncpg://cawnex:cawnex@localhost:5433/cawnex

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6380

# Encryption key for BYOL API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# GitHub PAT (repo scope) — for creating PRs, reading issues
GITHUB_TOKEN=

# Anthropic API key (BYOL — added after The Egg is built)
# ANTHROPIC_API_KEY=

# GitHub webhook secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
GITHUB_WEBHOOK_SECRET=
